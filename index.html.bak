bject-position:center;object-fit:cover"></div></div></div></div><div class="framer-8p593w" data-framer-name="Meet the bride and groom" id="bride-and-groom"><div class="framer-1kk7cdl" data-framer-name="Content"><div class="framer-i9koyx" data-framer-name="Heading"><div class="ssr-variant hidden-1qvbx5z"><div class="framer-1g0ji2r" data-framer-name="meet the" data-framer-component-type="RichTextContainer" style="transform:none"><p dir="auto" style="--font-selector:R0Y7QWJvcmV0by1yZWd1bGFy;--framer-font-family:&quot;Aboreto&quot;, sans-serif;--framer-font-size:30px;--framer-text-alignment:center;--framer-text-color:rgb(255, 255, 255)" class="framer-text">meet the</p></div></div><div class="ssr-variant hidden-nkfgwv hidden-1r8sxvb"><div class="framer-1g0ji2r" data-framer-name="meet the" data-framer-component-type="RichTextContainer" style="transform:none"><p dir="auto" style="--font-selector:R0Y7QWJvcmV0by1yZWd1bGFy;--framer-font-family:&quot;Aboreto&quot;, sans-serif;--framer-font-size:21px;--framer-text-alignment:center;--framer-text-color:rgb(255, 255, 255)" class="framer-text">meet the</p></div></div><div class="ssr-variant hidden-1qvbx5z"><div class="framer-l881zg" data-framer-name="bride and groom" data-framer-component-type="RichTextContainer" style="transform:none"><p dir="auto" style="--font-selector:R0Y7QWJvcmV0by1yZWd1bGFy;--framer-font-family:&quot;Aboreto&quot;, sans-serif;--framer-font-size:70px;--framer-text-alignment:center;--framer-text-color:rgb(255, 255, 255)" class="framer-text"> bride and groom</p></div></div><div class="ssr-variant hidden-nkfgwv hidden-1r8sxvb"><div class="framer-l881zg" data-framer-name="bride and groom" data-framer-component-type="RichTextContainer" style="transform:none"><p dir="auto" style="--font-selector:R0Y7QWJvcmV0by1yZWd1bGFy;--framer-font-family:&quot;Aboreto&quot;, sans-serif;--framer-font-size:45px;--framer-text-alignment:center;--framer-text-color:rgb(255, 255, 255)" class="framer-text"> bride and groom</p></div></div></div><div class="ssr-variant hidden-1qvbx5z"><div class="framer-1dr8p6b-container"><!--$--><div class="framer-9w4u8 framer-1r57amf framer-v-1r57amf" data-framer-name="Variant 1" style="height:100%;width:100%"><div class="framer-ojo0h1"><div class="framer-18yfxaf" data-framer-name="We are both so delighted that you are able to join us in celebrating what we hope will be one of the happiest days of our lives. The affection shown to us by so many people since our roka has been incredibly moving, and has touched us both deeply. We would like to take this opportunity to thank everyone most sincerely for their kindness. We are looking forward to see you at the wedding." data-framer-component-type="RichTextContainer" style="--extracted-r6o4lv:rgb(255, 255, 255);--framer-paragraph-spacing:0px;transform:none"><p dir="auto" class="framer-text" style="--font-selector:R0Y7WWFsZGV2aS1yZWd1bGFy;--framer-font-family:&quot;Yaldevi&quot;, &quot;Yaldevi Placeholder&quot;, sans-serif;--framer-font-size:20px;--framer-line-height:1.3em;--framer-text-alignment:center;--framer-text-color:var(--extracted-r6o4lv, rgb(255, 255, 255))">We are both so delighted that you will be joining us to celebrate what we hope will be one of the happiest days of our lives. The love and warmth shown to us by so many people since our Mangni has been incredibly moving and has touched us deeply. We would like to take this opportunity to thank everyone most sincerely for their kindness and prayers. We are truly looking forward to seeing you at the wedding functions.</p></div></div></div><!--/$--></div></div><div class="ssr-variant hidden-nkfgwv hidden-1r8sxvb"><div class="framer-1dr8p6b-container"><!--$--><div class="framer-9w4u8 framer-1r57amf framer-v-1r57amf" data-framer-name="Variant 1" style="width:100%"><div class="framer-ojo0h1"><div class="framer-18yfxaf" data-framer-name="We are both so delighted that you are able to join us in celebrating what we hope will be one of the happiest days of our lives. The affection shown to us by so many people since our roka has been incredibly moving, and has touched us both deeply. We would like to take this opportunity to thank everyone most sincerely for their kindness. We are looking forward to see you at the wedding." data-framer-component-type="RichTextContainer" style="--extracted-r6o4lv:rgb(255, 255, 255);--framer-paragraph-spacing:0px;transform:none"><p dir="auto" class="framer-text" style="--font-selector:R0Y7WWFsZGV2aS1yZWd1bGFy;--framer-font-family:&quot;Yaldevi&quot;, &quot;Yaldevi Placeholder&quot;, sans-serif;--framer-font-size:20px;--framer-line-height:1.3em;--framer-text-alignment:center;--framer-text-color:var(--extracted-r6o4lv, rgb(255, 255, 255))">We are both so delighted that you will be joining us to celebrate what we hope will be one of the happiest days of our lives. The love and warmth shown to us by so many people since our Mangni has been incredibly moving and has touched us deeply. We would like to take this opportunity to thank everyone most sincerely for their kindness and prayers. We are truly looking forward to seeing you at the wedding functions.</p></div></div></div><!--/$--></div></div></div><div class="ssr-variant hidden-1qvbx5z"><div class="framer-151kwqw-container"><!--$--><div class="framer-x7i99 framer-1v1xo58 framer-v-1v1xo58" data-framer-name="Desktop" style="width:100%"><div class="framer-1fvxhnu"><div class="framer-umirp" data-framer-name="The frame"><div style="position:absolute;border-radius:inherit;corner-shape:inherit;top:0;right:0;bottom:0;left:0" data-framer-background-image-wrapper="true"><img decoding="async" width="2064" height="3095" sizes="(min-width: 1400px) 691.09px, (min-width: 810px) and (max-width: 1399.98px) 691.09px, (max-width: 809.98px) 539px" srcset="/framerusercontent.com/images/fjBCUxg8Qw1hIeGsRaw4sjwus.png 682w,/framerusercontent.com/images/fjBCUxg8Qw1hIeGsRaw4sjwus.png 1365w,/framerusercontent.com/images/fjBCUxg8Qw1hIeGsRaw4sjwus.png 2064w" src="/framerusercon